# ── Neon PostgreSQL ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://neondb_owner:<password>@<endpoint>.neon.tech/neondb?sslmode=require

# ── Model Paths ────────────────────────────────────────────────────────────────
# Absolute or relative path to each checkpoint file
COATNET_PATH=./best_coatnet_model.pth
MAXVIT_PATH=./maxvit_kaggle_best.pth
NEXTVIT_PATH=../best_nextvit_checkpoint.pt

# ── Cloudinary ─────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Server ─────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
